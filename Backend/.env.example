# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Security
# 32-byte random string in hex (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your_64_char_hex_encryption_key_here
SESSION_SECRET=your_strong_session_secret_here
JWT_SECRET=your_strong_jwt_secret_here
JWT_EXPIRE=30d

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GENERIC_REDIRECT_URI=http://localhost:5000/auth/google/callback

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Frontend Environment Variables (for Vite/React)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_BACKEND_URL=http://localhost:5000